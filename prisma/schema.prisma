generator client {
  provider      = "prisma-client"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x"]
  output        = "./generated/prisma"
}

generator prismabox {
  provider                    = "prismabox"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
  inputModel                  = true
  output                      = "../generated/prismabox"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String?
  googleID           String?   @unique
  name               String
  onboarding         Boolean   @default(false)
  fcmToken           String?
  twoFactorCode      String?
  twoFactorExpiresAt DateTime?
  createdAt          DateTime  @default(now())

  routines              routine[]
  groups                groupMember[]
  sharedRoutinesCreated sharedRoutine[] @relation("SharedRoutineCreator")
  sharedRoutinesClaimed sharedRoutine[] @relation("SharedRoutineClaimer")
}

model routine {
  id            String   @id @default(uuid())
  name          String
  radius        Int      @default(50)
  triggerHour   Int?
  triggerMinute Int?
  triggerOnExit Boolean  @default(false)
  latitude      Float?
  longitude     Float?
  street        String?
  streetNumber  String?
  freeSpace     Int?
  createdAt     DateTime @default(now())

  userId String?
  user   user?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  groupId String?
  group   group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  items routineItem[]
}

model routineItem {
  id          String  @id @default(uuid())
  name        String
  description String?
  imageUrl    String?

  checkedBy String?
  checkedAt DateTime?

  routineId String
  routine   routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
}

model group {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique @default(cuid())
  createdAt  DateTime @default(now())

  members  groupMember[]
  routines routine[]
}

model groupMember {
  id String @id @default(uuid())

  groupId String
  group   group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  muted   Boolean?
  userId  String
  user    user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model sharedRoutine {
  id    String @id @default(uuid())
  token String @unique

  routineId     String
  routineName   String
  radius        Int
  triggerHour   Int?
  triggerMinute Int?
  triggerOnExit Boolean @default(false)
  latitude      Float?
  longitude     Float?
  street        String?
  streetNumber  String?
  freeSpace     Int?

  createdByUserId String
  createdBy       user   @relation("SharedRoutineCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  claimedAt       DateTime?
  claimedByUserId String?
  claimedBy       user?     @relation("SharedRoutineClaimer", fields: [claimedByUserId], references: [id], onDelete: SetNull)

  expiresAt DateTime?
  createdAt DateTime  @default(now())

  items sharedRoutineItem[]
}

model sharedRoutineItem {
  id          String  @id @default(uuid())
  name        String
  description String?
  imageUrl    String?

  sharedRoutineId String
  sharedRoutine   sharedRoutine @relation(fields: [sharedRoutineId], references: [id], onDelete: Cascade)
}
