generator client {
  provider      = "prisma-client"
  output        = "./generated/prisma"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x"]
}

generator prismabox {
  provider                    = "prismabox"
  output                      = "../generated/prismabox"
  inputModel                  = "true"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id                    String          @id @default(uuid())
  email                 String          @unique
  password              String?
  googleID              String?         @unique
  onboarding            Boolean         @default(false)
  name                  String
  createdAt             DateTime        @default(now())
  fcmToken              String?
  twoFactorCode         String?
  twoFactorExpiresAt    DateTime?
  groups                groupMember[]
  routines              routine[]
  sharedRoutinesClaimed sharedRoutine[] @relation("SharedRoutineClaimer")
  sharedRoutinesCreated sharedRoutine[] @relation("SharedRoutineCreator")
}

model routine {
  id             String        @id @default(uuid())
  name           String
  radius         Int           @default(50)
  triggerHour    Int?
  triggerMinute  Int?
  freeSpace      Int?
  latitude       Float?
  longitude      Float?
  street         String?
  streetNumber   String?
  createdAt      DateTime      @default(now())
  userId         String?
  groupId        String?
  triggerOnExit  Boolean       @default(false)
  activeDays     Json?
  timeframeEnd   String?
  timeframeStart String?
  weeklyPlan     Json?
  group          group?        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user           user?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          routineItem[]

  @@index([groupId], map: "routine_groupId_fkey")
  @@index([userId], map: "routine_userId_fkey")
}

model routineItem {
  id          String    @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  routineId   String
  checkedAt   DateTime?
  checkedBy   String?
  routine     routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId], map: "routineItem_routineId_fkey")
}

model group {
  id              String        @id @default(uuid())
  name            String
  inviteCode      String        @unique @default(cuid())
  createdAt       DateTime      @default(now())
  createdByUserId String?
  members         groupMember[]
  routines        routine[]
}

model groupMember {
  id      String   @id @default(uuid())
  groupId String
  userId  String
  muted   Boolean?
  group   group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId], map: "groupMember_userId_fkey")
}

model sharedRoutine {
  id              String              @id @default(uuid())
  token           String              @unique
  routineId       String
  routineName     String
  radius          Int
  triggerHour     Int?
  triggerMinute   Int?
  triggerOnExit   Boolean             @default(false)
  latitude        Float?
  longitude       Float?
  street          String?
  streetNumber    String?
  freeSpace       Int?
  createdByUserId String
  claimedAt       DateTime?
  claimedByUserId String?
  expiresAt       DateTime?
  createdAt       DateTime            @default(now())
  claimedBy       user?               @relation("SharedRoutineClaimer", fields: [claimedByUserId], references: [id])
  createdBy       user                @relation("SharedRoutineCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  items           sharedRoutineItem[]

  @@index([claimedByUserId], map: "sharedRoutine_claimedByUserId_fkey")
  @@index([createdByUserId], map: "sharedRoutine_createdByUserId_fkey")
}

model sharedRoutineItem {
  id              String        @id @default(uuid())
  name            String
  description     String?
  imageUrl        String?
  sharedRoutineId String
  sharedRoutine   sharedRoutine @relation(fields: [sharedRoutineId], references: [id], onDelete: Cascade)

  @@index([sharedRoutineId], map: "sharedRoutineItem_sharedRoutineId_fkey")
}
