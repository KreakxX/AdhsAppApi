generator client {
  provider      = "prisma-client"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x"]
  output        = "./generated/prisma"
}

generator prismabox {
  provider                    = "prismabox"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
  inputModel                  = true
  output                      = "../generated/prismabox"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id         String        @id @default(uuid())
  email      String        @unique
  password   String?
  googleID   String?       @unique
  name       String
  onboarding Boolean       @default(false)
  createdAt  DateTime      @default(now())
  fcmToken   String?
  routines   routine[]
  groups     groupMember[]
}

model routine {
  id            String   @id @default(uuid())
  name          String
  radius        Int      @default(50)
  triggerHour   Int      @default(0)
  triggerMinute Int      @default(0)
  freeSpace     Int      @default(5)
  latitude      Float?
  longitude     Float?
  street        String?
  streetNumber  String?
  createdAt     DateTime @default(now())

  userId String
  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items routineItem[]
}

model routineItem {
  id          String  @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  checked     Boolean @default(false)

  routineId String
  routine   routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
}

model group {
  id         String   @id @default(uuid())
  name       String
  inviteCode String   @unique @default(cuid())
  createdAt  DateTime @default(now())

  members   groupMember[]
  reminders sharedReminder[]
}

model groupMember {
  id String @id @default(uuid())

  groupId String
  group   group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  userId String
  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model sharedReminder {
  id            String   @id @default(uuid())
  title         String
  radius        Int      @default(80)
  triggerHour   Int      @default(0)
  triggerMinute Int      @default(0)
  latitude      Float?
  longitude     Float?
  street        String?
  streetNumber  String?
  createdAt     DateTime @default(now())

  groupId String
  group   group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
}
